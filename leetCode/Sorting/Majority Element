// Approach: Boyer-Moore Voting Algorithm to find majority element in linear time
// Time Complexity: O(n)
// Space Complexity: O(1)

int majorityElement(int* nums, int numsSize) {
    int candidate = 0;
    int count = 0;

    for (int i = 0; i < numsSize; i++) {
        if (count == 0) {
            candidate = nums[i];
        }

        if (nums[i] == candidate) {
            count++;
        } else {
            count--;
        }
    }

    return candidate;
}
