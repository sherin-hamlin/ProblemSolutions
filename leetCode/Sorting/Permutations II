// Approach: Backtracking with sorting and visited array to avoid duplicates
// Time Complexity: O(n!)
// Space Complexity: O(n)

#include <stdlib.h>
#include <stdbool.h>

// Comparator for sorting
int compare(const void* a, const void* b) {
    return (*(int*)a - *(int*)b);
}

void backtrack(int* nums, int numsSize, bool* used, int* temp,
               int** result, int* returnSize, int** returnColumnSizes) {

    if (*returnSize >= 10000) return; // safety

    int level = 0;
    while (level < numsSize && temp[level] != -11) level++;

    if (level == numsSize) {
        result[*returnSize] = (int*)malloc(numsSize * sizeof(int));
        for (int i = 0; i < numsSize; i++) {
            result[*returnSize][i] = temp[i];
        }
        (*returnColumnSizes)[*returnSize] = numsSize;
        (*returnSize)++;
        return;
    }

    for (int i = 0; i < numsSize; i++) {
        if (used[i]) continue;

        if (i > 0 && nums[i] == nums[i - 1] && !used[i - 1]) continue;

        used[i] = true;
        temp[level] = nums[i];

        backtrack(nums, numsSize, used, temp, result, returnSize, returnColumnSizes);

        used[i] = false;
        temp[level] = -11;
    }
}

int** permuteUnique(int* nums, int numsSize, int* returnSize, int** returnColumnSizes) {
    qsort(nums, numsSize, sizeof(int), compare);

    int** result = (int**)malloc(10000 * sizeof(int*));
    *returnColumnSizes = (int*)malloc(10000 * sizeof(int));
    *returnSize = 0;

    bool* used = (bool*)calloc(numsSize, sizeof(bool));
    int* temp = (int*)malloc(numsSize * sizeof(int));

    for (int i = 0; i < numsSize; i++) temp[i] = -11;

    backtrack(nums, numsSize, used, temp, result, returnSize, returnColumnSizes);

    free(used);
    free(temp);

    return result;
}
