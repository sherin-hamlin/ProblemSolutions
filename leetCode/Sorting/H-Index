// Approach: Use counting (bucket sort) to compute H-index efficiently
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <stdlib.h>

int hIndex(int* citations, int citationsSize) {
    int* bucket = (int*)calloc(citationsSize + 1, sizeof(int));

    // Fill buckets
    for (int i = 0; i < citationsSize; i++) {
        if (citations[i] >= citationsSize)
            bucket[citationsSize]++;
        else
            bucket[citations[i]]++;
    }

    int count = 0;

    // Traverse from high to low
    for (int i = citationsSize; i >= 0; i--) {
        count += bucket[i];
        if (count >= i) {
            free(bucket);
            return i;
        }
    }

    free(bucket);
    return 0;
}
