// Approach: Dynamic Programming – use 2D DP table to match string and pattern
// Time Complexity: O(n * m)
// Space Complexity: O(n * m)

#include <stdio.h>
#include <string.h>

int isMatch(char *s, char *p) {
    int n = strlen(s);
    int m = strlen(p);

    int dp[n+1][m+1];

    // Initialize all to 0
    for (int i = 0; i <= n; i++) {
        for (int j = 0; j <= m; j++) {
            dp[i][j] = 0;
        }
    }

    dp[0][0] = 1;

    // Handle patterns like a*, a*b*, etc.
    for (int j = 2; j <= m; j++) {
        if (p[j-1] == '*') {
            dp[0][j] = dp[0][j-2];
        }
    }

    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= m; j++) {

            if (p[j-1] == '.' || s[i-1] == p[j-1]) {
                dp[i][j] = dp[i-1][j-1];
            }

            else if (p[j-1] == '*') {
                dp[i][j] = dp[i][j-2];  // 0 occurrence

                if (p[j-2] == '.' || s[i-1] == p[j-2]) {
                    dp[i][j] |= dp[i-1][j]; // 1+ occurrence
                }
            }
        }
    }

    return dp[n][m];
}
