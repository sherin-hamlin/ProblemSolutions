// Approach: Stack – store indices to track valid substring boundaries
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int longestValidParentheses(char *s) {
    int n = strlen(s);

    int *stack = (int *)malloc(sizeof(int) * (n + 1));
    int top = -1;

    // Push base index
    stack[++top] = -1;

    int maxLen = 0;

    for (int i = 0; i < n; i++) {
        if (s[i] == '(') {
            stack[++top] = i;
        } else {
            top--; // pop

            if (top == -1) {
                stack[++top] = i; // reset base
            } else {
                int len = i - stack[top];
                if (len > maxLen) maxLen = len;
            }
        }
    }

    free(stack);
    return maxLen;
}
