// Approach: Use two pointers and swap elements from both ends | Time: O(n) | Space: O(1)

void reverseString(char* s, int sSize) {
    
    int left = 0;
    int right = sSize - 1;
    
    while(left < right)
    {
        char temp = s[left];
        s[left] = s[right];
        s[right] = temp;
        
        left++;
        right--;
    }
}
