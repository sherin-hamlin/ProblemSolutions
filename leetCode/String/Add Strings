// Approach: simulate addition from right to left with carry | Time: O(n) | Space: O(n)

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char* addStrings(char* num1, char* num2) {

    int n1 = strlen(num1);
    int n2 = strlen(num2);

    int max = (n1 > n2 ? n1 : n2) + 2;

    char* result = (char*)malloc(max);
    result[max-1] = '\0';

    int i = n1 - 1;
    int j = n2 - 1;
    int k = max - 2;
    int carry = 0;

    while(i >= 0 || j >= 0 || carry)
    {
        int sum = carry;

        if(i >= 0) sum += num1[i--] - '0';
        if(j >= 0) sum += num2[j--] - '0';

        result[k--] = (sum % 10) + '0';
        carry = sum / 10;
    }

    return &result[k+1];
}
