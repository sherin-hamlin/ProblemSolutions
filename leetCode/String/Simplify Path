// Approach: Stack + String Parsing – process path components
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char* simplifyPath(char* path) {
    int n = strlen(path);

    char **stack = (char **)malloc(sizeof(char *) * n);
    int top = -1;

    char *token = strtok(path, "/");

    while (token != NULL) {
        if (strcmp(token, "..") == 0) {
            if (top >= 0) top--;
        }
        else if (strcmp(token, ".") != 0 && strlen(token) > 0) {
            stack[++top] = token;
        }
        token = strtok(NULL, "/");
    }

    // Build result
    char *result = (char *)malloc(n + 1);
    result[0] = '\0';

    if (top == -1) {
        strcpy(result, "/");
    } else {
        for (int i = 0; i <= top; i++) {
            strcat(result, "/");
            strcat(result, stack[i]);
        }
    }

    return result;
}
