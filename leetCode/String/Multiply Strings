// Approach: Simulation (Grade-school multiplication using array)
// Time Complexity: O(n * m)
// Space Complexity: O(n + m)

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char* multiply(char* num1, char* num2) {
    if (strcmp(num1, "0") == 0 || strcmp(num2, "0") == 0) {
        char *zero = (char *)malloc(2);
        strcpy(zero, "0");
        return zero;
    }

    int n = strlen(num1);
    int m = strlen(num2);

    int *result = (int *)calloc(n + m, sizeof(int));

    // Multiply digits
    for (int i = n - 1; i >= 0; i--) {
        for (int j = m - 1; j >= 0; j--) {
            int mul = (num1[i] - '0') * (num2[j] - '0');
            int sum = mul + result[i + j + 1];

            result[i + j + 1] = sum % 10;
            result[i + j] += sum / 10;
        }
    }

    // Convert to string
    char *resStr = (char *)malloc(n + m + 1);
    int k = 0, i = 0;

    // Skip leading zeros
    while (i < n + m && result[i] == 0) i++;

    for (; i < n + m; i++) {
        resStr[k++] = result[i] + '0';
    }

    resStr[k] = '\0';

    free(result);
    return resStr;
}
