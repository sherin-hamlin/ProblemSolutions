// Approach: Greedy + Simulation – build lines and distribute spaces
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char** fullJustify(char** words, int wordsSize, int maxWidth, int* returnSize) {
    char **result = (char **)malloc(sizeof(char *) * wordsSize);
    *returnSize = 0;

    int i = 0;

    while (i < wordsSize) {
        int lineLen = 0, j = i;

        // Step 1: find words for current line
        while (j < wordsSize &&
               lineLen + strlen(words[j]) + (j - i) <= maxWidth) {
            lineLen += strlen(words[j]);
            j++;
        }

        int gaps = j - i - 1;
        char *line = (char *)malloc(maxWidth + 1);
        int pos = 0;

        // Step 2: last line OR single word → left justify
        if (j == wordsSize || gaps == 0) {
            for (int k = i; k < j; k++) {
                int len = strlen(words[k]);
                memcpy(line + pos, words[k], len);
                pos += len;

                if (pos < maxWidth) {
                    line[pos++] = ' ';
                }
            }
            // fill remaining spaces
            while (pos < maxWidth) line[pos++] = ' ';
        }

        // Step 3: fully justify
        else {
            int totalSpaces = maxWidth - lineLen;
            int spaceEach = totalSpaces / gaps;
            int extra = totalSpaces % gaps;

            for (int k = i; k < j; k++) {
                int len = strlen(words[k]);
                memcpy(line + pos, words[k], len);
                pos += len;

                if (k < j - 1) {
                    int spaces = spaceEach + (extra-- > 0 ? 1 : 0);
                    for (int s = 0; s < spaces; s++) {
                        line[pos++] = ' ';
                    }
                }
            }
        }

        line[maxWidth] = '\0';
        result[(*returnSize)++] = line;

        i = j;
    }

    return result;
}
