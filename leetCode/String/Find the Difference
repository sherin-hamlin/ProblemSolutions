// Approach: XOR all characters from s and t, duplicates cancel leaving the extra character | Time: O(n) | Space: O(1)

char findTheDifference(char * s, char * t){

    char result = 0;

    int i = 0;

    while(s[i] != '\0')
    {
        result ^= s[i];
        i++;
    }

    i = 0;

    while(t[i] != '\0')
    {
        result ^= t[i];
        i++;
    }

    return result;
}
