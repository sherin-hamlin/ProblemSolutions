// Approach: Count frequency of characters using array of size 26 | Time: O(n) | Space: O(1)

#include <stdio.h>
#include <string.h>
#include <stdbool.h>

bool isAnagram(char* s, char* t) {
    
    if(strlen(s) != strlen(t))
        return false;

    int count[26] = {0};

    for(int i = 0; s[i]; i++)
        count[s[i] - 'a']++;

    for(int i = 0; t[i]; i++)
        count[t[i] - 'a']--;

    for(int i = 0; i < 26; i++)
        if(count[i] != 0)
            return false;

    return true;
}
