// Approach: Sliding Window + Hashing – expand and shrink window
// Time Complexity: O(n)
// Space Complexity: O(1)

#include <stdio.h>
#include <string.h>
#include <limits.h>

char* minWindow(char* s, char* t) {
    int need[256] = {0};
    int window[256] = {0};

    int sLen = strlen(s);
    int tLen = strlen(t);

    // Build need array
    for (int i = 0; i < tLen; i++) {
        need[(unsigned char)t[i]]++;
    }

    int required = 0;
    for (int i = 0; i < 256; i++) {
        if (need[i] > 0) required++;
    }

    int left = 0, right = 0;
    int formed = 0;

    int minLen = INT_MAX;
    int start = 0;

    while (right < sLen) {
        char c = s[right];
        window[(unsigned char)c]++;

        if (need[(unsigned char)c] > 0 &&
            window[(unsigned char)c] == need[(unsigned char)c]) {
            formed++;
        }

        // Try to shrink
        while (left <= right && formed == required) {

            if (right - left + 1 < minLen) {
                minLen = right - left + 1;
                start = left;
            }

            char leftChar = s[left];
            window[(unsigned char)leftChar]--;

            if (need[(unsigned char)leftChar] > 0 &&
                window[(unsigned char)leftChar] < need[(unsigned char)leftChar]) {
                formed--;
            }

            left++;
        }

        right++;
    }

    if (minLen == INT_MAX) return "";

    static char result[100000];
    strncpy(result, s + start, minLen);
    result[minLen] = '\0';

    return result;
}
