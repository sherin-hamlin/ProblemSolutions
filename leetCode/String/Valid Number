// Approach: String Parsing using flags
// Time Complexity: O(n)
// Space Complexity: O(1)

#include <stdio.h>
#include <ctype.h>

int isNumber(char *s) {
    int i = 0;

    // skip leading spaces
    while (s[i] == ' ') i++;

    int numSeen = 0, dotSeen = 0, eSeen = 0, numAfterE = 1;

    for (; s[i] != '\0'; i++) {

        if (isdigit(s[i])) {
            numSeen = 1;
            numAfterE = 1;
        }

        else if (s[i] == '+' || s[i] == '-') {
            // valid only at start or after e/E
            if (i > 0 && s[i-1] != 'e' && s[i-1] != 'E')
                return 0;
        }

        else if (s[i] == '.') {
            if (dotSeen || eSeen) return 0;
            dotSeen = 1;
        }

        else if (s[i] == 'e' || s[i] == 'E') {
            if (eSeen || !numSeen) return 0;
            eSeen = 1;
            numAfterE = 0;
        }

        else if (s[i] == ' ') {
            // skip trailing spaces
            while (s[i] == ' ') i++;
            return s[i] == '\0' && numSeen && numAfterE;
        }

        else {
            return 0;
        }
    }

    return numSeen && numAfterE;
}
