// Approach: Two-pointer technique to swap vowels from both ends | Time: O(n) | Space: O(1)

#include <stdbool.h>

bool isVowel(char c)
{
    return (c=='a'||c=='e'||c=='i'||c=='o'||c=='u'||
            c=='A'||c=='E'||c=='I'||c=='O'||c=='U');
}

char* reverseVowels(char* s) {

    int left = 0;
    int right = 0;

    while(s[right] != '\0')
        right++;

    right--;

    while(left < right)
    {
        while(left < right && !isVowel(s[left]))
            left++;

        while(left < right && !isVowel(s[right]))
            right--;

        char temp = s[left];
        s[left] = s[right];
        s[right] = temp;

        left++;
        right--;
    }

    return s;
}
