// Approach: Kadane’s Algorithm, track current max subarray sum and global maximum
// Time Complexity: O(n)
// Space Complexity: O(1)

int max(int a, int b) {
    return a > b ? a : b;
}

int maxSubArray(int* nums, int numsSize) {
    int curr = nums[0];
    int best = nums[0];

    for (int i = 1; i < numsSize; i++) {
        curr = max(nums[i], curr + nums[i]);
        best = max(best, curr);
    }

    return best;
}
