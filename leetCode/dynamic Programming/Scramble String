// Approachh: Recursion + Memoization, try all splits and check swapped & non-swapped cases
// Time Complexity: O(n^4)
// Space Complexity: O(n^3)

#include <stdbool.h>
#include <string.h>
#include <stdlib.h>

int memo[31][31][31];

bool solve(char* s1, char* s2, int i1, int i2, int len) {
    if (memo[i1][i2][len] != -1) return memo[i1][i2][len];

    if (strncmp(s1 + i1, s2 + i2, len) == 0)
        return memo[i1][i2][len] = 1;

    int count[26] = {0};
    for (int k = 0; k < len; k++) {
        count[s1[i1 + k] - 'a']++;
        count[s2[i2 + k] - 'a']--;
    }
    for (int k = 0; k < 26; k++) {
        if (count[k] != 0)
            return memo[i1][i2][len] = 0;
    }

    for (int k = 1; k < len; k++) {
        if ((solve(s1, s2, i1, i2, k) &&
             solve(s1, s2, i1 + k, i2 + k, len - k)) ||
            (solve(s1, s2, i1, i2 + len - k, k) &&
             solve(s1, s2, i1 + k, i2, len - k))) {
            return memo[i1][i2][len] = 1;
        }
    }

    return memo[i1][i2][len] = 0;
}

bool isScramble(char* s1, char* s2) {
    int n = strlen(s1);
    if (n != strlen(s2)) return false;

    memset(memo, -1, sizeof(memo));
    return solve(s1, s2, 0, 0, n);
}
