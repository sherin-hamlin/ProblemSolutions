// Approach: DP, dp[i] = ways to decode substring up to i using single-digit and valid two-digit checks
// Timme Complexity: O(n)
// Space Complexity: O(1)

#include <string.h>

int numDecodings(char* s) {
    int n = strlen(s);
    if (n == 0 || s[0] == '0') return 0;

    int prev2 = 1;
    int prev1 = 1;

    for (int i = 1; i < n; i++) {
        int curr = 0;

        if (s[i] != '0') {
            curr += prev1;
        }

        int two = (s[i-1] - '0') * 10 + (s[i] - '0');
        if (two >= 10 && two <= 26) {
            curr += prev2;
        }

        prev2 = prev1;
        prev1 = curr;
    }

    return prev1;
}
