// Approachm: Greedy – add all positive differences (profit whenever next day price is higher)
// Time Complexity: O(n)
// Space Complexity: O(1)

#include <stdio.h>

int maxProfit(int* prices, int pricesSize) {
    int profit = 0;

    for (int i = 1; i < pricesSize; i++) {
        if (prices[i] > prices[i - 1]) {
            profit += prices[i] - prices[i - 1];
        }
    }

    return profit;
}
