// Approach: DP, dp[i][j] = min operations to convert first i chars of word1 to first j chars of word2
// Timme Complexity: O(m * n)
// Space Complexity: O(n)

#include <string.h>
#include <stdlib.h>

int min(int a, int b) {
    return a < b ? a : b;
}

int minDistance(char* word1, char* word2) {
    int m = strlen(word1);
    int n = strlen(word2);

    int* prev = (int*)malloc((n + 1) * sizeof(int));
    int* curr = (int*)malloc((n + 1) * sizeof(int));

    for (int j = 0; j <= n; j++) {
        prev[j] = j;
    }

    for (int i = 1; i <= m; i++) {
        curr[0] = i;
        for (int j = 1; j <= n; j++) {
            if (word1[i - 1] == word2[j - 1]) {
                curr[j] = prev[j - 1];
            } else {
                curr[j] = 1 + min(prev[j - 1], min(prev[j], curr[j - 1]));
            }
        }
        int* temp = prev;
        prev = curr;
        curr = temp;
    }

    int result = prev[n];
    free(prev);
    free(curr);
    return result;
}
