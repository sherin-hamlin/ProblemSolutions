/* 
Approach: Use two pointers—move fast n steps ahead, then move both until fast reaches end so slow is just before the node to delete.
Time Complexity: O(n)
Space Complexity: O(1)
*/

struct ListNode* removeNthFromEnd(struct ListNode* head, int n) {
    struct ListNode dummy;
    dummy.next = head;

    struct ListNode *fast = &dummy;
    struct ListNode *slow = &dummy;

    for(int i = 0; i <= n; i++)
        fast = fast->next;

    while(fast != NULL) {
        fast = fast->next;
        slow = slow->next;
    }

    struct ListNode* temp = slow->next;
    slow->next = temp->next;

    return dummy.next;
}
