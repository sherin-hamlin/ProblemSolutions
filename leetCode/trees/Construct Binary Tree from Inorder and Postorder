/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     struct TreeNode *left;
 *     struct TreeNode *right;
 * };
 */

// Recursive inorder postorder split
// Time Complexity: O(n^2), Space Complexity: O(n)

struct TreeNode* build(int* inorder, int inStart, int inEnd, int* postorder, int* postIdx) {
    if (inStart > inEnd) return NULL;

    // Root is always at the current end of postorder array
    struct TreeNode* root = (struct TreeNode*)malloc(sizeof(struct TreeNode));
    root->val = postorder[(*postIdx)--];

    // Find the division point in the inorder array
    int mid = inEnd;
    while (inorder[mid] != root->val) {
        mid--;
    }

    // Build right subtree first (Postorder: Left -> Right -> Root)
    root->right = build(inorder, mid + 1, inEnd, postorder, postIdx);
    root->left = build(inorder, inStart, mid - 1, postorder, postIdx);

    return root;
}

struct TreeNode* buildTree(int* inorder, int inorderSize, int* postorder, int postorderSize) {
    int postIdx = postorderSize - 1;
    return build(inorder, 0, inorderSize - 1, postorder, &postIdx);
}
