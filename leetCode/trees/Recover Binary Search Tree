/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     struct TreeNode *left;
 *     struct TreeNode *right;
 * };
 */

// Inorder traversal swap recovery
// Time Complexity: O(n), Space Complexity: O(n)

struct TreeNode *first, *second, *prev;

void findNodes(struct TreeNode* root) {
    if (root == NULL) return;
    
    findNodes(root->left);
    
    // Identify the two nodes that are out of order
    if (prev != NULL && root->val < prev->val) {
        if (first == NULL) {
            first = prev;   // First violation
            second = root;  // Potential second violation
        } else {
            second = root;  // Actual second violation
        }
    }
    prev = root;
    
    findNodes(root->right);
}

void recoverTree(struct TreeNode* root) {
    first = second = prev = NULL;
    findNodes(root);
    
    // Swap the values of the two identified nodes
    int temp = first->val;
    first->val = second->val;
    second->val = temp;
}
