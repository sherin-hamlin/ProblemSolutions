// Approach: Track visited numbers and maintain current mex; update mex while it exists in prefix | Time: O(N) | Space: O(N)

#include <stdio.h>
#include <stdlib.h>

int main() {
    
    int n;
    scanf("%d", &n);

    int *arr = (int*)malloc(n * sizeof(int));
    int *visited = (int*)calloc(n + 2, sizeof(int));

    for(int i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    int mex = 0;

    for(int i = 0; i < n; i++)
    {
        if(arr[i] <= n)
            visited[arr[i]] = 1;

        while(visited[mex])
            mex++;

        printf("%d ", mex);
    }

    free(arr);
    free(visited);

    return 0;
}
